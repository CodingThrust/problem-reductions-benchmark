# Generated HF Dataset bundle (rebuild with `build_dataset.py`)
dataset/

# Local scoring output (backend_score / score-local writes here)
results/

# Runner output (docker run -v ./out:/out writes submission.json here)
out/

# Python bytecode
__pycache__/
*.pyc

# Subagent-driven-development scratch (ledger, briefs, review packages)
.superpowers/

# Private accept-path bug fixtures — the benchmark answer key, never publish
benchmark/tests/fixtures/private/

# Build-baked version pins (written into the image from PR_REF; not source-controlled)
benchmark/PINNED_COMMIT
benchmark/PINNED_VERSION

# Filled-in submission config — may hold an API key (template is submission.env.example)
submission.env
*.submission.env

# macOS
.DS_Store
