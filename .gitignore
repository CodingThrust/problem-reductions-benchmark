# Local scoring output (backend_score / score-local writes here). Root-anchored so it does
# NOT match the tracked per-submission board under site/results/.
/results/

# Deployed board — generated from site/results/*.json at publish (build-board); not committed.
/site/results.json

# R2 sync scratch (score-from-r2 workflow / local scoring pulls here) — holds raw
# submissions with certificates; never commit.
incoming/
processed/

# Raw submissions are the answer key (cert + trajectory) — they must NEVER enter the
# public repo. They live in a private store (self-run: local; Phase 1: private HF dataset).
# The public repo carries only the aggregate site/results.json. Keep submissions/README.md.
submissions/*.json
submissions/**/*.json

# Runner output (docker run -v ./out:/out writes submission.json here)
out/

# Python bytecode
__pycache__/
*.pyc

# Subagent-driven-development scratch (ledger, briefs, review packages)
.superpowers/

# Private accept-path bug fixtures — the benchmark answer key, never publish
benchmark/tests/fixtures/private/

# Build-baked version pins (written into the image from PR_REF; not source-controlled)
benchmark/PINNED_COMMIT
benchmark/PINNED_VERSION

# Filled-in submission config — may hold an API key (template is submission.env.example)
submission.env
*.submission.env

# Cloudflare Wrangler local state/cache (intake Worker)
.wrangler/
node_modules/

# macOS
.DS_Store
