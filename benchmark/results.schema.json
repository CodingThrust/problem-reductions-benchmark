{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "results.schema.json",
  "title": "BenchmarkResults",
  "description": "Output of one benchmark run: model, library version, summary metrics, and per-rule details.",
  "type": "object",
  "required": ["model", "library_commit", "bugs_found", "total_cost_usd", "total_tokens_k", "efficiency_bugs_per_ktok", "efficiency_bugs_per_dollar", "rules_tested", "results"],
  "properties": {
    "model": {
      "type": "string",
      "description": "LiteLLM model name (e.g. 'anthropic/claude-sonnet-4-6')"
    },
    "library_commit": {
      "type": "string",
      "description": "Full git commit hash of the problem-reductions library used"
    },
    "bugs_found": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of verified, novel bugs found"
    },
    "total_cost_usd": {
      "type": "number",
      "minimum": 0,
      "description": "Total spend in USD"
    },
    "total_tokens_k": {
      "type": "number",
      "minimum": 0,
      "description": "Total tokens used (in thousands)"
    },
    "efficiency_bugs_per_ktok": {
      "type": "number",
      "minimum": 0,
      "description": "Primary fair metric: bugs per 1000 tokens"
    },
    "efficiency_bugs_per_dollar": {
      "type": "number",
      "minimum": 0,
      "description": "Practical metric: bugs per dollar spent"
    },
    "rules_tested": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of rules the model attempted"
    },
    "results": {
      "type": "array",
      "description": "Per-rule results",
      "items": {
        "type": "object",
        "required": ["rule", "result", "cost", "tokens_k"],
        "properties": {
          "rule": {
            "type": "string",
            "description": "Rule name (filename stem from src/rules/)"
          },
          "result": {
            "type": "string",
            "enum": ["bug_found", "known_issue", "no_certificate", "rejected", "no_bug", "error"],
            "description": "Outcome for this rule"
          },
          "cost": {
            "type": "number",
            "minimum": 0
          },
          "tokens_k": {
            "type": "number",
            "minimum": 0
          },
          "steps": {
            "type": "integer",
            "minimum": 0
          },
          "certificate": {
            "type": "object",
            "description": "Counterexample certificate (present only when result=bug_found or rejected)",
            "properties": {
              "rule": {"type": "string"},
              "violation": {
                "type": "string",
                "enum": ["unsound_extraction", "incomplete_reduction", "suboptimal_extraction"]
              },
              "source": {"type": "object"},
              "bundle": {"type": "object"},
              "target_config": {"type": "string"},
              "claimed_source_solution": {"type": "array"},
              "brute_force_solution": {"type": "array"},
              "note": {"type": "string"}
            },
            "required": ["rule", "violation", "source", "bundle"]
          },
          "verify_details": {
            "type": "object",
            "description": "Details from independent verification (keys vary by violation type)"
          },
          "reject_reason": {
            "type": "string",
            "description": "Why the certificate was rejected (present only when result=rejected)"
          }
        }
      }
    }
  },
  "additionalProperties": false
}
